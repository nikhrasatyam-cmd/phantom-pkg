{
  "name": "phantom-pkg",
  "version": "0.1.0",
  "description": "Validate LLM-recommended npm packages before you install them",
  "type": "module",
  "bin": {
    "phantom-pkg": "dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/add-shebang.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "npm",
    "security",
    "llm",
    "ai",
    "hallucination",
    "typosquat",
    "supply-chain",
    "validation",
    "cli"
  ],
  "author": "Satyam Nikhra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikhrasatyam-cmd/phantom-pkg.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
